# Copy this file to .env and set your secret keys locally.
# Do NOT commit your real secrets to Git.

# Pinecone credentials
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=your_pinecone_environment_here
PINECONE_INDEX_NAME=visa-index

# Local RAG DB paths
UK_VISA_DB_PATH=./uk_visa_db
INDIA_VISA_DB_PATH=./visa_db

# Ollama / Local LLM settings
# OLLAMA_URL=http://localhost:11434/api/generate
# OLLAMA_MODEL=llama2
# LLM_API_KEY=lm-studio
# OPENAI_API_KEY=your_openai_api_key_here

# Optional LLM provider overrides
LLM_BASE_URL=http://localhost:1234/v1
MODEL_NAME=google/gemma-4-e4b
LM_STUDIO_API_KEY=lm-studio
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=local-model
